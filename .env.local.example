# Base URL - for local development, use http://localhost:3000
# For production or with ngrok, update to your actual domain
# BASE_URL="https://mycustomdomain.com"

# Encryption key for GitHub tokens - generate with: openssl rand -base64 32
CRYPTO_KEY="random-string-of-characters"

# GitHub App configuration - get these from your GitHub App settings
GITHUB_APP_ID="your-github-app-id"
GITHUB_APP_NAME="your-github-app-machine-name"
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
xxx
-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET="another-random-string-of-characters"
GITHUB_APP_CLIENT_ID="your-github-app-client-id"
GITHUB_APP_CLIENT_SECRET="your-github-app-client-secret"

# Email service configuration - get from Resend.com
RESEND_API_KEY="your-resend-api-key"
RESEND_FROM_EMAIL="Pages CMS <no-reply@mail.pagescms.org>"

# Database configuration
# For local development (SQLite):
DATABASE_URL="file:./local.db"
# For production with PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/pagescms"
# For Docker Compose with PostgreSQL:
# DATABASE_URL="postgresql://pagescms:pagescms_password@postgres:5432/pagescms"

# Optional cache configuration
# FILE_CACHE_TTL=1440
# PERMISSION_CACHE_TTL=60

# Cron endpoint security
CRON_SECRET="a-random-string-of-characters"